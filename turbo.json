{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "out/**",
                "dist/**"
            ]
        },
        "check": {
            "dependsOn": [
                "^check"
            ]
        },
        "lint": {
            "dependsOn": []
        },
        "format": {
            "dependsOn": []
        },
        "test": {
            "dependsOn": [
                "build"
            ]
        },
        "test:coverage": {
            "dependsOn": [
                "build"
            ],
            "outputs": [
                ".coverage/**",
                "coverage/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}