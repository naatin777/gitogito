{
  "name": "gitogito",
  "version": "0.0.0",
  "description": "AI-powered CLI for generating smart commit messages and GitHub issues.",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "typecheck": "bunx tsc --noEmit",
