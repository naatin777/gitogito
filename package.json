    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "@reduxjs/toolkit": "^2.11.2",
    "ai": "^6.0.116",
    "diff": "^8.0.4",
    "isomorphic-git": "^1.37.4",
    "lodash": "^4.17.23",
    "octokit": "^5.0.5",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.1",
    "simple-git": "^3.35.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
