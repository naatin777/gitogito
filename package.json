{
  "name": "gitogito",
  "version": "0.0.0",
  "description": "AI-powered CLI for generating smart commit messages and GitHub issues.",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "bun run src/main.ts",
    "typecheck": "bunx tsc --noEmit",
    "check": "bun run typecheck",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=coverage"
  },
  "dependencies": {
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@octokit/openapi-types": "^27.0.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "@reduxjs/toolkit": "^2.11.2",
    "ai": "^6.0.116",
    "lodash": "^4.17.23",
    "octokit": "^5.0.5",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.13.1",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3"
  }
