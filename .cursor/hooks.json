{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "pnpm format",
        "matcher": "apps/.*\\.(ts|tsx|js|jsx|json)$|packages/.*\\.(ts|tsx|js|jsx|json)$"
      },
      {
        "command": "pnpm check",
        "matcher": "apps/.*\\.(ts|tsx|js|jsx)$|packages/.*\\.(ts|tsx|js|jsx)$"
      }
    ],
    "stop": [
      {
        "command": "pnpm test"
      }
    ],
    "beforeShellExecution": [
      {
        "type": "prompt",
        "prompt": "Is this command destructive or irreversible? Commands like rm, git push, git reset, git rebase are high risk. Block if so.",
        "matcher": "rm|git push|git reset|git rebase"
      }
    ]
  }
}