{
  "name": "@gitogito/tui",
  "version": "0.0.1",
  "description": "AI-powered TUI for generating smart commit messages and GitHub issues.",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/main.ts",
    "check": "bun tsc --noEmit",
    "format": "biome format --write src",
    "lint": "biome check src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-dir=./.coverage"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@cliffy/command": "npm:@jsr/cliffy__command@^1.0.1",
    "@commitlint/core": "^20.5.2",
    "@gitogito/core": "workspace:*",
    "@gitogito/shared": "workspace:*",
    "@octokit/openapi-types": "^27.0.0",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@opentui/core": "^0.1.103",
    "@opentui/react": "^0.1.103",
    "@reduxjs/toolkit": "^2.11.2",
    "ai": "^6.0.168",
    "diff": "^9.0.0",
    "i18next": "^26.0.8",
    "i18next-fs-backend": "^2.6.5",
    "isomorphic-git": "^1.37.5",
    "neverthrow": "catalog:",
    "octokit": "^5.0.5",
    "ollama-ai-provider-v2": "^3.5.0",
    "react": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.2",
    "simple-git": "^3.36.0",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.13"
  },
  "bin": {
    "gito": "./src/main.ts"
  },
  "displayName": "gitogito",
  "type": "module"
}
